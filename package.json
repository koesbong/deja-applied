{
  "name": "deja-applied",
  "version": "1.0.0",
  "description": "Chrome extension: never accidentally apply to the same job twice",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "tests/parser-shim.js"
    ]
  }
}
